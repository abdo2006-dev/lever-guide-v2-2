# Copy to .env and fill in values
# NEVER commit .env to version control

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to production in deployed environments. Wildcard CORS is ignored in production.
APP_ENV=development

# Optional Analysis Copilot (RAG answer generation through Groq)
# Keep the real key in .env or your host's secret manager; never commit it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30

# Optional in-memory RAG index settings
RAG_INDEX_TTL_SECONDS=21600
RAG_VECTOR_SIZE=4096
RAG_MAX_CONTEXT_CHARS=7000

# Qdrant-backed Copilot storage
# Leave QDRANT_URL blank to use local persistent mode at QDRANT_PATH.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=./.qdrant
QDRANT_COLLECTION=analysis_copilot
QDRANT_TIMEOUT_SECONDS=10

# Python logging level
LOG_LEVEL=INFO
