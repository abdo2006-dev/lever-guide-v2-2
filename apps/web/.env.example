# Copy to .env.local and fill in values
# NEVER commit .env.local to version control

# URL of your deployed Python API (Render / Railway / Fly.io)
# Leave blank when FastAPI serves the exported frontend from the same origin.
# For Next.js local dev, set this to http://localhost:8000.
NEXT_PUBLIC_API_URL=

# Example for production:
# NEXT_PUBLIC_API_URL=https://lever-guide-api.onrender.com
